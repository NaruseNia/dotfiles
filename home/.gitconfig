	signingkey = 7D2542E62E24ABB7
[gpg]
	program = gpg
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[include]
  path = ~/.config/delta/themes.gitconfig
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	dark = true
[merge]
	conflictStyle = zdiff3
