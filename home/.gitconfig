[gpg]
	program = gpg
[commit]
	gpgsign = true
[tag]
	gpgsign = true
# Portable defaults generated by nix/home.nix (only present when the Nix
# setup has been applied; harmless to include otherwise — git silently
# skips missing include paths).
[include]
	path = ~/.config/git/nix.inc
[include]
	path = ~/.config/delta/themes.gitconfig
