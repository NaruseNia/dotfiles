# Personal identity (name / email / signing key / gpg / commit / tag)
# lives in ~/.gitconfig.local — create it manually on each machine.
# Git silently skips missing include paths, so this file remains valid
# even before ~/.gitconfig.local exists.
#
# Example ~/.gitconfig.local:
#   [user]
#       name = Your Name
#       email = you@example.com
#       signingkey = XXXXXXXXXXXXXXXX
#   [gpg]
#       program = gpg
#   [commit]
#       gpgsign = true
#   [tag]
#       gpgsign = true

[include]
	path = ~/.config/git/nix.inc
[include]
	path = ~/.config/delta/themes.gitconfig
[include]
	path = ~/.gitconfig.local
